#!/bin/sh
# TAP producer for WCS encoding-conversion regression tests.
#
# Runs wcsconverter on each case listed in wcsconv_tests.txt (the same data
# file the CMake test suite reads) and checks its output two ways, matching
# the CMake suite:
#   - ast_astequal: a semantic (astEqual) comparison against the reference,
#     run for every case;
#   - exact diff against the reference, run unless the case is flagged
#     skip_string_compare (those fixtures have ulp-level output variation
#     between platforms, so a byte comparison is not a reliable gate).
# One TAP result is emitted per case; a case passes only if all its applicable
# checks pass.
srcdir=${srcdir:-.}
data=${srcdir}/wcsconv_tests.txt

trim() {
    printf '%s' "$1" | sed 's/^[[:blank:]]*//; s/[[:blank:]]*$//'
}

# TAP plan: the number of data (non-blank, non-comment) lines.
echo "1..$(grep -cvE '^[[:blank:]]*(#|$)' "$data")"

idx=0
while IFS='|' read -r name input reference encoding attrs skip rest; do
    name=$(trim "$name")
    case $name in ''|'#'*) continue ;; esac
    input=$(trim "$input")
    reference=$(trim "$reference")
    encoding=$(trim "$encoding")
    attrs=$(trim "$attrs")
    skip=$(trim "$skip")

    idx=$((idx + 1))
    test="$idx - $name"
    out=${name}.out
    rm -f "$out"

    if [ -n "$attrs" ]; then
        ./wcsconverter "${srcdir}/${input}" "$encoding" "$out" "$attrs" \
            > "${out}.log" 2>&1 < /dev/null
    else
        ./wcsconverter "${srcdir}/${input}" "$encoding" "$out" \
            > "${out}.log" 2>&1 < /dev/null
    fi

    if [ $? -ne 0 ]; then
        echo "not ok $test"
        sed 's/^/# /' "${out}.log"
        rm -f "$out" "${out}.log"
        continue
    fi

    ok=1
    # String diff (skipped for ulp-variant fixtures).
    if [ "$skip" != yes ]; then
        if ! diff -u "${srcdir}/${reference}" "$out" > "${out}.diff" 2>&1; then
            ok=0
            echo "# $name: string diff against reference failed"
            sed 's/^/# /' "${out}.diff"
        fi
    fi
    # Semantic comparison (always).
    if ! ./ast_astequal "${srcdir}/${reference}" "$out" "$encoding" "$attrs" \
            > "${out}.eq" 2>&1 < /dev/null; then
        ok=0
        echo "# $name: ast_astequal reported not equal to reference"
        sed 's/^/# /' "${out}.eq"
    fi

    if [ "$ok" -eq 1 ]; then
        echo "ok $test"
    else
        echo "not ok $test"
    fi
    rm -f "$out" "${out}.log" "${out}.diff" "${out}.eq"
done < "$data"
