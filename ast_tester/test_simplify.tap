#!/bin/sh
# TAP producer for Mapping-simplification regression tests.
#
# Runs simplify on each case listed in simplify_tests.txt (the same data file
# the CMake test suite reads) and checks its output two ways, matching the
# CMake suite:
#   - ast_astequal: a semantic (astEqual) comparison against the reference,
#     run for every case;
#   - exact diff against the reference, run unless the case is flagged
#     skip_string_compare (ulp-level output variation between platforms).
#
# TODO: Eventually add a numerically aware diff program as an alternative;
# remove skip_string_compare
#
# One TAP result is emitted per case; a case passes only if all its applicable
# checks pass.  simplify writes AST-Channel dumps, so ast_astequal reads them
# with the "ast" encoding.
srcdir=${srcdir:-.}
data=${srcdir}/simplify_tests.txt

trim() {
    printf '%s' "$1" | sed 's/^[[:blank:]]*//; s/[[:blank:]]*$//'
}

# TAP plan: the number of data (non-blank, non-comment) lines.
echo "1..$(grep -cvE '^[[:blank:]]*(#|$)' "$data")"

idx=0
while IFS='|' read -r name input reference skip rest; do
    name=$(trim "$name")
    case $name in ''|'#'*) continue ;; esac
    input=$(trim "$input")
    reference=$(trim "$reference")
    skip=$(trim "$skip")

    idx=$((idx + 1))
    test="$idx - $name"
    out=${name}.out
    rm -f "$out"

    ./simplify "${srcdir}/${input}" "$out" > "${out}.log" 2>&1 < /dev/null
    if [ $? -ne 0 ]; then
        echo "not ok $test"
        sed 's/^/# /' "${out}.log"
        rm -f "$out" "${out}.log"
        continue
    fi

    ok=1
    # String diff (skipped for ulp-variant fixtures).
    if [ "$skip" != yes ]; then
        if ! diff -u "${srcdir}/${reference}" "$out" > "${out}.diff" 2>&1; then
            ok=0
            echo "# $name: string diff against reference failed"
            sed 's/^/# /' "${out}.diff"
        fi
    fi
    # Semantic comparison (always).
    if ! ./ast_astequal "${srcdir}/${reference}" "$out" ast \
            > "${out}.eq" 2>&1 < /dev/null; then
        ok=0
        echo "# $name: ast_astequal reported not equal to reference"
        sed 's/^/# /' "${out}.eq"
    fi

    if [ "$ok" -eq 1 ]; then
        echo "ok $test"
    else
        echo "not ok $test"
    fi
    rm -f "$out" "${out}.log" "${out}.diff" "${out}.eq"
done < "$data"
