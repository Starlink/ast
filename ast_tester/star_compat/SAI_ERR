*  SAI_ERR -- Error code definitions for the SAI (Starlink Applications Interface)
*  Minimal standalone version for building AST tests without the Starlink MERS library.
*
*  The only constants used by AST tests are SAI__OK (0, always) and SAI__ERROR
*  (any non-zero value indicating a bad status).

*     OK status
      INTEGER SAI__OK
      PARAMETER ( SAI__OK = 0 )

*     Warning status
      INTEGER SAI__WARN
      PARAMETER ( SAI__WARN = 146800643 )

*     Error status
      INTEGER SAI__ERROR
      PARAMETER ( SAI__ERROR = 146800770 )
