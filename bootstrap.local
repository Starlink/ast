#!/bin/sh -
# Minimal bootstrap script intended for building outside the Starlink
# environment; if you get
#
# bootstrap error: The starconf application is not in your path
#
# ... this is for you.
#
# This will generate a working `configure` script, from which you can then
# run:
#
# $ ./configure
# $ make
#
# and optionally
#
# $ make check

autoreconf --install --symlink
